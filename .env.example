# Copy this file to .env and fill in your keys
# Never commit .env to git

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — used as fallback data sources
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here   # free at alphavantage.co
FRED_API_KEY=your_fred_api_key_here              # free at fred.stlouisfed.org
NEWS_API_KEY=your_news_api_key_here              # free at newsapi.org
